# Redis
REDIS_URL=redis://redis:6379

# Database
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_db

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=qdrant_key_12345

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cache TTLs (seconds)
EMBEDDING_CACHE_TTL=86400
RETRIEVAL_CACHE_TTL=14400
RESPONSE_CACHE_TTL=7200

# Context Compression
CONTEXT_COMPRESSION_MAX_CHUNKS=5
CONTEXT_COMPRESSION_MAX_TOKENS=2500
