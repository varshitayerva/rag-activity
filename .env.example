# Hugging Face Inference API (RECOMMENDED - Free Forever)
HF_TOKEN=hf_your_token_here

# Alternative LLM Providers
GROQ_API_KEY=gsk_your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL + pgvector (MAIN DATABASE FOR VECTOR + TEXT SEARCH)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fde_rag
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fde_rag

# Optional: Redis for Response Caching (improves performance but not required)
REDIS_URL=redis://localhost:6379

# (Deprecated: Qdrant no longer needed - PostgreSQL pgvector handles all vector operations)
# QDRANT_URL=http://localhost:6333

# Cache TTLs (seconds)
EMBEDDING_CACHE_TTL=86400
RETRIEVAL_CACHE_TTL=14400
RESPONSE_CACHE_TTL=7200

# Context Compression
CONTEXT_COMPRESSION_MAX_CHUNKS=5
CONTEXT_COMPRESSION_MAX_TOKENS=2500

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Generation Provider
GENERATION_PROVIDER=huggingface

# Environment
ENVIRONMENT=development
DEBUG=true
