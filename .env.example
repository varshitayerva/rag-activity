# Hugging Face Inference API (RECOMMENDED - Free Forever)
HF_TOKEN=hf_your_token_here

# Alternative LLM Providers
GROQ_API_KEY=gsk_your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/rag_db

# Redis
REDIS_URL=redis://redis:6379

# Qdrant Vector DB
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=qdrant_key_12345

# Cache TTLs (seconds)
EMBEDDING_CACHE_TTL=86400
RETRIEVAL_CACHE_TTL=14400
RESPONSE_CACHE_TTL=7200

# Context Compression
CONTEXT_COMPRESSION_MAX_CHUNKS=5
CONTEXT_COMPRESSION_MAX_TOKENS=2500

# Frontend Configuration
VITE_API_URL=http://localhost:8000

# Generation Provider
GENERATION_PROVIDER=huggingface

# Environment
ENVIRONMENT=development
DEBUG=true
