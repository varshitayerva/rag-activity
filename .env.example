# Hugging Face Inference API (RECOMMENDED - Free Forever)
# Get token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Or use alternative providers:
GROQ_API_KEY=gsk_your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/rag_db

# Qdrant Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=qdrant_key_12345

# Generation Provider
GENERATION_PROVIDER=huggingface

# Cache TTLs (seconds)
EMBEDDING_CACHE_TTL=86400
RETRIEVAL_CACHE_TTL=14400
RESPONSE_CACHE_TTL=7200

# Context Compression
CONTEXT_COMPRESSION_MAX_CHUNKS=5
CONTEXT_COMPRESSION_MAX_TOKENS=2500
